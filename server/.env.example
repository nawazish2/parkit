# ParkIt Server Environment Variables

# Database
DATABASE_URL=mysql://root:password@localhost:3306/parkit

# Authentication
JWT_SECRET=your_jwt_secret_here

# Razorpay Payment Gateway (optional — falls back to demo mode)
RAZORPAY_KEY_ID=rzp_test_your_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Client URL for CORS
CLIENT_URL=http://localhost:5173

# Server Port
PORT=5001

# Environment (development | production)
NODE_ENV=development
